# --- Supabase (database + order storage) ---
# Create a free project at https://supabase.com, then run supabase/schema.sql
# in the SQL editor. Keys are under Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Lipia Online (M-Pesa STK push) ---
# Generate the API key from the Lipia Online app's "Security" tab:
# https://lipia-online.vercel.app/
LIPIA_API_KEY=
LIPIA_BASE_URL=https://lipia-online.vercel.app

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
